rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserData() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function sameInstitutionCode(code) {
      return signedIn()
        && currentUserData() != null
        && code != null
        && currentUserData().institutionCode == code;
    }

    function sameInstitutionFromUserDoc(userData) {
      return signedIn()
        && currentUserData() != null
        && userData != null
        && userData.institutionCode != null
        && currentUserData().institutionCode == userData.institutionCode;
    }

    function isMonitor() {
      return signedIn()
        && currentUserData() != null
        && (
          currentUserData().role in ["monitor", "monitora", "Monitor", "Monitora"]
          || currentUserData().accountType in ["monitor", "monitora", "Monitor", "Monitora"]
        );
    }

    match /institutions/{institutionId} {
      allow get: if true;
      allow list: if false;
      allow update: if sameInstitutionCode(institutionId)
        && request.resource.data.code == resource.data.code
        && request.resource.data.name == resource.data.name
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["lat", "lng", "address"]);
      allow create, delete: if false;

      match /students/{studentCode} {
        allow get: if true;
        allow list: if false;
        allow create, update, delete: if false;
      }

      match /routes/{routeId} {
        allow get, list: if signedIn();
        allow create, update, delete: if false;

        match /addresses/{addressId} {
          allow get, list: if signedIn();
          allow create, update, delete: if false;
        }

        match /direcciones/{addressId} {
          allow get, list: if signedIn();
          allow create, update, delete: if false;
        }

        match /stops/{addressId} {
          allow get, list: if signedIn();
          allow create, update, delete: if false;
        }
      }

      match /rutas/{routeId} {
        allow get, list: if signedIn();
        allow create, update, delete: if false;

        match /addresses/{addressId} {
          allow get, list: if signedIn();
          allow create, update, delete: if false;
        }

        match /direcciones/{addressId} {
          allow get, list: if signedIn();
          allow create, update, delete: if false;
        }

        match /stops/{addressId} {
          allow get, list: if signedIn();
          allow create, update, delete: if false;
        }
      }
    }

    match /colegios/{schoolId} {
      allow get: if signedIn();
      allow list: if false;
      allow create, update, delete: if false;

      match /routes/{routeId} {
        allow get, list: if signedIn();
        allow create, update, delete: if false;

        match /addresses/{addressId} {
          allow get, list: if signedIn();
          allow create, update, delete: if false;
        }

        match /direcciones/{addressId} {
          allow get, list: if signedIn();
          allow create, update, delete: if false;
        }

        match /stops/{addressId} {
          allow get, list: if signedIn();
          allow create, update, delete: if false;
        }
      }

      match /rutas/{routeId} {
        allow get, list: if signedIn();
        allow create, update, delete: if false;

        match /addresses/{addressId} {
          allow get, list: if signedIn();
          allow create, update, delete: if false;
        }

        match /direcciones/{addressId} {
          allow get, list: if signedIn();
          allow create, update, delete: if false;
        }

        match /stops/{addressId} {
          allow get, list: if signedIn();
          allow create, update, delete: if false;
        }
      }
    }

    match /studentCodes/{studentCode} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /studentAccounts/{studentCode} {
      allow get: if true;
      allow list: if false;
      allow create, update: if signedIn()
        && request.resource.data.code == studentCode
        && request.resource.data.uid == request.auth.uid
        && exists(/databases/$(database)/documents/studentCodes/$(studentCode))
        && request.resource.data.institutionCode
          == get(/databases/$(database)/documents/studentCodes/$(studentCode)).data.institutionCode;
      allow delete: if false;
    }

    match /routes/{routeId} {
      allow get, list: if signedIn();
      allow create, update, delete: if false;

      match /addresses/{addressId} {
        allow get, list: if signedIn();
        allow create, update, delete: if false;
      }

      match /direcciones/{addressId} {
        allow get, list: if signedIn();
        allow create, update, delete: if false;
      }

      match /stops/{addressId} {
        allow get, list: if signedIn();
        allow create, update, delete: if false;
      }

      match /live/{docId} {
        allow read: if signedIn();
        allow create, update: if signedIn()
          && request.resource.data.uid == request.auth.uid;
        allow delete: if false;
      }

      match /daily/{dateId}/stops/{stopId} {
        allow read: if signedIn();
        allow create, update, delete: if isMonitor()
          && request.resource.data.monitorUid == request.auth.uid
          && sameInstitutionCode(request.resource.data.institutionCode);
      }
    }

    match /rutas/{routeId} {
      allow get, list: if signedIn();
      allow create, update, delete: if false;

      match /addresses/{addressId} {
        allow get, list: if signedIn();
        allow create, update, delete: if false;
      }

      match /direcciones/{addressId} {
        allow get, list: if signedIn();
        allow create, update, delete: if false;
      }

      match /stops/{addressId} {
        allow get, list: if signedIn();
        allow create, update, delete: if false;
      }

      match /daily/{dateId}/stops/{stopId} {
        allow read: if signedIn();
        allow create, update, delete: if isMonitor()
          && request.resource.data.monitorUid == request.auth.uid
          && sameInstitutionCode(request.resource.data.institutionCode);
      }
    }

    match /users/{uid} {
      allow read: if signedIn()
        && (request.auth.uid == uid || sameInstitutionFromUserDoc(resource.data));
      allow create, update: if signedIn()
        && request.auth.uid == uid;
      allow delete: if false;

      match /asistencias/{dateId} {
        allow read: if signedIn()
          && (request.auth.uid == uid || sameInstitutionFromUserDoc(
            get(/databases/$(database)/documents/users/$(uid)).data
          ));
        allow create, update, delete: if signedIn()
          && (
            request.auth.uid == uid
            || (
              isMonitor()
              && sameInstitutionFromUserDoc(
                get(/databases/$(database)/documents/users/$(uid)).data
              )
            )
          );
      }

      match /notifications/{notificationId} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow create, update, delete: if false;
      }
    }

    match /routePushStates/{stateId} {
      allow read, write: if false;
    }
  }
}
